{
  "info": {
    "_postman_id": "e5d5090f-7790-4ba7-9dbc-a3f91ddce24c",
    "name": "API_Testing_Framework",
    "description": "End-to-end API testing framework for CRM application including authentication, CRUD operations, validations, and data-driven testing.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
    "_exporter_id": "53748657",
